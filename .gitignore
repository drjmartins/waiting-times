# Source CSVs: large (~230MB) and re-downloadable; CI re-fetches, never commits.
data/raw/

# RTT raw monthly Full-CSV zips (~175MB) — re-fetched by the pipeline, never
# committed. The derived per-org JSON under site/rtt/data IS committed (~2MB).
data_rtt/raw/*.zip

# Dev-only synthetic store (kept separate from the real store so it can never
# seed a real run). Never belongs in the repo.
data/processed/tidy_synthetic.parquet

# Download artefacts (per-FY CSVs, headline extract, gzipped full file). Large
# and rebuilt every run into the site/ Pages artefact; not stored in git.
site/cancer/data/downloads/

# Load-on-demand per-org breakdown files (~43MB across all orgs). Rebuilt every
# run from the committed store into the Pages artefact, same as downloads/; the
# lean all-slice org/<CODE>.json stays committed for fast first paint.
site/cancer/data/org/*.breakdown.json
site/cancer/data/national.breakdown.json

# RTT load-on-demand per-org + national treatment-function breakdown files
# (~9.6MB) — rebuilt every run, same pattern as the cancer breakdown files. The
# lean core org/<CODE>.json stays committed.
site/rtt/data/org/*.breakdown.json
site/rtt/data/national.breakdown.json

# Local dev verification screenshots (not part of the site or pipeline)
screenshots/

# Local dev render harness (puppeteer-core + system Chrome) for screenshots /
# export samples; not part of the site or pipeline.
render.mjs
render_rtt.mjs
node_modules/
package.json
package-lock.json

# Python / OS cruft
__pycache__/
*.py[cod]
.pytest_cache/
.DS_Store
