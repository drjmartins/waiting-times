# Source CSVs: large (~230MB) and re-downloadable; CI re-fetches, never commits.
data/raw/

# Dev-only synthetic store (kept separate from the real store so it can never
# seed a real run). Never belongs in the repo.
data/processed/tidy_synthetic.parquet

# Download artefacts (per-FY CSVs, headline extract, gzipped full file). Large
# and rebuilt every run into the site/ Pages artefact; not stored in git.
site/data/downloads/

# Local dev verification screenshots (not part of the site or pipeline)
screenshots/

# Python / OS cruft
__pycache__/
*.py[cod]
.pytest_cache/
.DS_Store
